# Required secret NAMES only — NEVER commit real values.
# Copy to .env (gitignored) and fill in locally; in CI these come from GitHub Secrets.

# YNAB Personal Access Token — YNAB → Account Settings → Developer Settings → New Token
YNAB_PAT=

# YNAB budget UUID — YNAB app URL or GET /budgets via the API
YNAB_BUDGET_ID=

# Anthropic API key — Anthropic Console → API Keys
ANTHROPIC_API_KEY=
